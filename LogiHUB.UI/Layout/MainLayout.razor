@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage

<div class="app-shell">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="logo">LogiHUB</div>

        <nav class="sidebar-nav">
            
            @if (!IsLoggedIn)
            {
                <button class="sidebar-btn @(IsActive("/"))" @onclick="@(() => NavigateTo("/"))">
                    <i class="bi bi-house"></i>
                    Home
                </button>

                <button class="sidebar-btn @(IsActive("/about"))" @onclick="@(() => NavigateTo("/about"))">
                    <i class="bi bi-info-circle"></i>
                    About
                </button>
            }

            @if (IsLoggedIn)
            {
                <button class="sidebar-btn @(IsActive("/client"))" @onclick="@(() => NavigateTo("/client"))">
                    <i class="bi bi-person"></i>
                    Client
                </button>

                <button class="sidebar-btn @(IsActive("/dashboard"))" @onclick="@(() => NavigateTo("/dashboard"))">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard
                </button>

                <button class="sidebar-btn @(IsActive("/shipments"))" @onclick="@(() => NavigateTo("/shipments"))">
                    <i class="bi bi-truck"></i>
                    Shipments
                </button>

                <button class="sidebar-btn @(IsActive("/customers"))" @onclick="@(() => NavigateTo("/customers"))">
                    <i class="bi bi-people"></i>
                    Customers
                </button>

                <button class="sidebar-btn @(IsActive("/invoices"))" @onclick="@(() => NavigateTo("/invoices"))">
                    <i class="bi bi-receipt"></i>
                    Invoices
                </button>

                <button class="sidebar-btn @(IsActive("/about"))" @onclick="@(() => NavigateTo("/about"))">
                    <i class="bi bi-info-circle"></i>
                    About
                </button>
            }

        </nav>
    </aside>

    <!-- Main Area -->
    <div class="main-area">

        <header class="topbar">
            <span>Logistics Management Platform</span>
        </header>

        <main class="content">
            @Body
        </main>

    </div>

</div>

@code {
    private bool IsLoggedIn = false;

    protected override async Task OnInitializedAsync()
    {
        IsLoggedIn = await LocalStorage.ContainKeyAsync("authToken");
    }

    private void NavigateTo(string url)
    {
        Navigation.NavigateTo(url);
    }

    private string IsActive(string href)
    {
        return Navigation.Uri.EndsWith(href, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
}