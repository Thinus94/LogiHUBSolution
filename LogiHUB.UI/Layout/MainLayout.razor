@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="app-shell">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="logo">LogiHUB</div>

        <nav class="sidebar-nav">
            <button class="sidebar-btn" @onclick="@(() => NavigateTo("/"))">Home</button>
            <button class="sidebar-btn" @onclick="@(() => NavigateTo("/dashboard"))">Dashboard</button>
            <button class="sidebar-btn" @onclick="@(() => NavigateTo("/shipments"))">Shipments</button>
            <button class="sidebar-btn" @onclick="@(() => NavigateTo("/customers"))">Customers</button>
            <button class="sidebar-btn" @onclick="@(() => NavigateTo("/invoices"))">Invoices</button>
            <button class="sidebar-btn" @onclick="@(() => NavigateTo("/about"))">About</button>
        </nav>
    </aside>

    <!-- Main Area -->
    <div class="main-area">

        <header class="topbar">
            <span>Logistics Management Platform</span>
        </header>

        <main class="content">
            @Body
        </main>

    </div>

</div>

@code {
    private void NavigateTo(string url)
    {
        Navigation.NavigateTo(url);
    }
}