@page "/edit-customer"
@page "/edit-customer/{Id:guid}"

@inject CustomerService CustomerService
@inject NavigationManager NavigationManager

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="page-blur-container">
        <h3>@(IsEditMode ? "Edit Customer" : "Add Customer")</h3>

        <EditForm Model="customer" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label>Name</label>
                <InputText class="form-control" @bind-Value="customer.Name" />
                <ValidationMessage For="@(() => customer.Name)" />
            </div>

            <div class="mb-3">
                <label>Email</label>
                <InputText class="form-control" @bind-Value="customer.Email" />
                <ValidationMessage For="@(() => customer.Email)" />
            </div>

            <div class="mb-3">
                <label>Phone</label>
                <InputText class="form-control" @bind-Value="customer.Phone" />
                <ValidationMessage For="@(() => customer.Phone)" />
            </div>

            <div class="mb-3">
                <label>Address</label>
                <InputText class="form-control" @bind-Value="customer.Address" />
                <ValidationMessage For="@(() => customer.Address)" />
            </div>

            <button type="submit" class="btn btn-success me-2">
                @(IsEditMode ? "Update" : "Add")
            </button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </EditForm>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private Customer customer = new();
    private bool isLoading = false;
    private bool IsEditMode => Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode)
        {
            try
            {
                isLoading = true;
                var existing = await CustomerService.GetByIdAsync(Id!.Value);
                if (existing == null) { NavigationManager.NavigateTo("/customers"); return; }
                customer = existing;
            }
            finally { isLoading = false; }
        }
    }

    private async Task HandleValidSubmit()
    {
        if (IsEditMode)
            await CustomerService.UpdateAsync(customer);
        else
            await CustomerService.CreateAsync(customer);

        NavigationManager.NavigateTo("/customers");
    }

    private void Cancel() => NavigationManager.NavigateTo("/customers");
}