@page "/edit-customer"
@page "/edit-customer/{Id:guid}"

@inject CustomerService CustomerService
@inject NavigationManager NavigationManager

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="page-blur-container">
        <h3>@(IsEditMode ? "Edit Customer" : "Add Customer")</h3>

        <EditForm Model="FormModel" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Name</label>
                @if (IsEditMode)
                {
                    <InputText class="form-control" @bind-Value="editDto.Name" />
                    <ValidationMessage For="@(() => editDto.Name)" />
                }
                else
                {
                    <InputText class="form-control" @bind-Value="createDto.Name" />
                    <ValidationMessage For="@(() => createDto.Name)" />
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                @if (IsEditMode)
                {
                    <InputText class="form-control" @bind-Value="editDto.Email" />
                    <ValidationMessage For="@(() => editDto.Email)" />
                }
                else
                {
                    <InputText class="form-control" @bind-Value="createDto.Email" />
                    <ValidationMessage For="@(() => createDto.Email)" />
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Phone</label>
                @if (IsEditMode)
                {
                    <InputText class="form-control" @bind-Value="editDto.Phone" />
                    <ValidationMessage For="@(() => editDto.Phone)" />
                }
                else
                {
                    <InputText class="form-control" @bind-Value="createDto.Phone" />
                    <ValidationMessage For="@(() => createDto.Phone)" />
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Address</label>
                @if (IsEditMode)
                {
                    <InputText class="form-control" @bind-Value="editDto.Address" />
                    <ValidationMessage For="@(() => editDto.Address)" />
                }
                else
                {
                    <InputText class="form-control" @bind-Value="createDto.Address" />
                    <ValidationMessage For="@(() => createDto.Address)" />
                }
            </div>
            
            @if (IsEditMode)
            {
                <div class="mb-3 form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="editDto.IsActive" />
                    <label class="form-check-label">Active</label>
                </div>
            }

            <button type="submit" class="btn btn-success me-2">
                @(IsEditMode ? "Update" : "Add")
            </button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </EditForm>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private CreateCustomerDto createDto = new();
    private UpdateCustomerDto editDto = new();
    private bool isLoading = false;
    private bool IsEditMode => Id.HasValue;
    private object FormModel => IsEditMode ? editDto : createDto;

    protected override async Task OnInitializedAsync()
    {
        if (!IsEditMode) return;

        try
        {
            isLoading = true;

            var existing = await CustomerService.GetByIdAsync(Id!.Value);

            if (existing == null)
            {
                NavigationManager.NavigateTo("/customers");
                return;
            }

            editDto = new UpdateCustomerDto
            {
                Id = existing.Id,
                Name = existing.Name,
                Email = existing.Email,
                Phone = existing.Phone,
                Address = existing.Address,
                IsActive = existing.IsActive
            };
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (IsEditMode)
            await CustomerService.UpdateAsync(editDto);
        else
            await CustomerService.CreateAsync(createDto);

        NavigationManager.NavigateTo("/customers");
    }

    private void Cancel() => NavigationManager.NavigateTo("/customers");
}