@page "/shipments"
@inject ShipmentService ShipmentService
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<!-- Glass Blur Container -->
<div class="page-blur-container">
    <!-- Header -->
    <div class="shipments-header d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Shipments</h3>

        <button class="btn btn-success" @onclick="CreateShipment">
            + Create Shipment
        </button>
    </div>

    <!-- Loading / Error / Empty State -->
    @if (isLoading)
    {
        <p><em>Loading shipments...</em></p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (shipments.Count == 0)
    {
        <p>No shipments found.</p>
    }
    else
    {
        <div class="filter-panel">

            <input class="form-control"
                   placeholder="Search shipments..."
                   @bind="searchTerm"
                   @bind:event="oninput"
                   @bind:after="OnFilterChanged" />

            <select class="form-select"
                    @bind="statusFilter"
                    @bind:after="OnFilterChanged">
                <option value="">All Statuses</option>
                <option value="Created">Created</option>
                <option value="In Transit">In Transit</option>
                <option value="Delivered">Delivered</option>
                <option value="Delayed">Delayed</option>
                <option value="Cancelled">Cancelled</option>
            </select>

            <select class="form-select"
                    @bind="pageSize"
                    @bind:after="OnFilterChanged">

                <option @value="10">10</option>
                <option @value="25">25</option>
                <option @value="50">50</option>

            </select>

        </div>

        <!-- Table -->
        <div class="table-responsive table-container">
            <table class="table table-glass table-hover">
                <thead>
                <tr>
                    <th>Shipment Number</th>
                    <th>Origin</th>
                    <th>Destination</th>
                    <th>Status</th>
                    <th>Pickup</th>
                    <th>Delivery</th>
                    <th>Weight (kg)</th>
                    <th>Customer</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var shipment in shipments)
                {
                    <tr @onclick="() => OpenShipment(shipment)">
                        <td>@shipment.ShipmentNumber</td>
                        <td>@shipment.Origin</td>
                        <td>@shipment.Destination</td>
                        <td>
                            <span class="status-badge @GetStatusClass(shipment.Status)">
                                @shipment.Status
                            </span>
                        </td>
                        <td>@shipment.PickupDate.ToShortDateString()</td>
                        <td>@shipment.DeliveryDate?.ToShortDateString()</td>
                        <td>@shipment.WeightKg</td>
                        <td>@shipment.CustomerName</td>
                        <td>
                            <button class="btn btn-sm btn-primary"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => EditShipment(shipment.Id))">
                                Edit
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => DeleteShipment(shipment.Id))">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="pagination-controls">

            <button class="btn btn-secondary"
                    disabled="@(pageNumber == 1)"
                    @onclick="PrevPage">
                Previous
            </button>

            <span>Page @pageNumber</span>

            <button class="btn btn-secondary"
                    disabled="@((pageNumber * pageSize) >= totalCount)"
                    @onclick="NextPage">
                Next
            </button>

        </div>

        @if (showShipmentModal && selectedShipment != null)
        {
            <div class="modal-overlay">
                <div class="modal-card">

                    <div class="modal-header">
                        <h4>Shipment Details</h4>
                        <button class="btn-close" @onclick="CloseShipmentModal"></button>
                    </div>

                    <div class="modal-body">

                        <p><b>Shipment Number:</b> @selectedShipment.ShipmentNumber</p>
                        <p><b>Status:</b> @selectedShipment.Status</p>
                        <p><b>Origin:</b> @selectedShipment.Origin</p>
                        <p><b>Destination:</b> @selectedShipment.Destination</p>
                        <p><b>Pickup:</b> @selectedShipment.PickupDate.ToShortDateString()</p>
                        <p><b>Delivery:</b> @selectedShipment.DeliveryDate?.ToShortDateString()</p>
                        <p><b>Weight:</b> @selectedShipment.WeightKg kg</p>
                        <p><b>Customer:</b> @selectedShipment.CustomerName</p>
                        <ShipmentTimeline Status="@selectedShipment.Status" />
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-primary"
                                @onclick="@(() => EditShipment(selectedShipment.Id))">
                            Edit
                        </button>
                        @if (selectedShipment.InvoiceId.HasValue)
                        {
                            <button class="btn btn-info"
                                    @onclick="@(() => OpenInvoice(selectedShipment.InvoiceId.Value))">
                                Open Invoice: @selectedShipment.InvoiceNumber
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-warning"
                                    @onclick="@(() => CreateInvoice(selectedShipment.Id, selectedShipment.CustomerId))">
                                Create Invoice
                            </button>
                        }
                        <button class="btn btn-secondary"
                                @onclick="CloseShipmentModal">
                            Close
                        </button>
                    </div>

                </div>
            </div>
        }
    }
</div>

@code {
    private List<ShipmentResponseDto> shipments = new();
    private ShipmentResponseDto? selectedShipment;
    [Parameter]
    [SupplyParameterFromQuery]
    public Guid? CustomerId { get; set; }
    private bool showShipmentModal = false;
    private bool isLoading = true;
    private string? errorMessage;
    string searchTerm = "";
    string statusFilter = "";

    int pageNumber = 1;
    int pageSize = 10;

    int totalCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadShipments();
    }

    private async Task LoadShipments()
    {
        try
        {
            isLoading = true;
            var result = await ShipmentService.GetAllAsync(
                searchTerm,
                statusFilter,
                CustomerId,
                pageNumber,
                pageSize);

            shipments = result.Items;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading shipments: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Created" => "status-created",
            "In Transit" => "status-transit",
            "Delivered" => "status-delivered",
            "Delayed" => "status-delayed",
            "Cancelled" => "status-cancelled",
            _ => ""
        };
    }

    async Task OnFilterChanged()
    {
        pageNumber = 1;
        await LoadShipments();
    }

    async Task NextPage()
    {
        pageNumber++;
        await LoadShipments();
    }

    async Task PrevPage()
    {
        pageNumber--;
        await LoadShipments();
    }

    private void OpenShipment(ShipmentResponseDto shipment)
    {
        selectedShipment = shipment;
        showShipmentModal = true;
    }

    private void CreateInvoice(Guid shipmentId, Guid customerId)
    {
        var shipment = shipments.FirstOrDefault(s => s.Id == shipmentId);

        if (shipment?.InvoiceId != null)
        {
            // If invoice already exists, open it
            OpenInvoice(shipment.InvoiceId.Value);
            return;
        }

        NavigationManager.NavigateTo($"/edit-invoice?shipmentId={shipmentId}&customerId={customerId}");
    }

    private void OpenInvoice(Guid invoiceId)
    {
        NavigationManager.NavigateTo($"/edit-invoice/{invoiceId}");
    }

    private void CloseShipmentModal()
    {
        showShipmentModal = false;
    }

    private void CreateShipment()
    {
        NavigationManager.NavigateTo("/edit-shipment");
    }

    private void EditShipment(Guid id)
    {
        NavigationManager.NavigateTo($"/edit-shipment/{id}");
    }

    private async Task DeleteShipment(Guid id)
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this shipment?"))
        {
            try
            {
                await ShipmentService.DeleteAsync(id);
                await LoadShipments(); // refresh list
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting shipment: {ex.Message}";
            }
        }
    }
}