@page "/shipments"

@inject ShipmentService ShipmentService
@inject NavigationManager NavigationManager

<!-- Glass Blur Container -->
<div class="page-blur-container">
    <!-- Header -->
    <div class="shipments-header d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Shipments</h3>

        <button class="btn btn-success" @onclick="CreateShipment">
            + Create Shipment
        </button>
    </div>

    <!-- Loading / Error / Empty State -->
    @if (isLoading)
    {
        <p><em>Loading shipments...</em></p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else
    {
        <!-- ALWAYS SHOW FILTERS -->
        <div class="filter-panel">

            <input class="form-control"
                   placeholder="Search shipments..."
                   @bind="searchTerm"
                   @bind:event="oninput"
                   @bind:after="OnFilterChanged" />

            <select class="form-select"
                    @bind="statusFilter"
                    @bind:after="OnFilterChanged">
                <option value="">All Statuses</option>
                <option value="Created">Created</option>
                <option value="InTransit">In Transit</option>
                <option value="Delivered">Delivered</option>
                <option value="Delayed">Delayed</option>
                <option value="Cancelled">Cancelled</option>
            </select>

            <select class="form-select"
                    @bind="pageSize"
                    @bind:after="OnFilterChanged">
                <option @value="10">10</option>
                <option @value="25">25</option>
                <option @value="50">50</option>
            </select>

            <select class="form-select" 
                    @bind="activeFilterString" 
                    @bind:after="OnActiveChanged">
                <option value="">All records</option>
                <option value="true">Active records</option>
                <option value="false">Inactive records</option>
            </select>

        </div>

        @if (shipments.Count == 0)
        {
            <p>No shipments found.</p>
        }
        else
        {
            <!-- Table -->
            <div class="table-responsive table-container">
                <table class="table table-glass table-hover">
                    <thead>
                    <tr>
                        <th>Shipment Number</th>
                        <th>Origin</th>
                        <th>Destination</th>
                        <th>Status</th>
                        <th>Pickup</th>
                        <th>Delivery</th>
                        <th>Weight (kg)</th>
                        <th>Customer</th>
                        <th>Invoices</th>
                        <th>Created Date</th>
                        <th>Active</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var shipment in shipments)
                    {
                        <tr @onclick="() => OpenShipment(shipment.Id)">
                            <td>@shipment.ShipmentNumber</td>
                            <td>@shipment.Origin</td>
                            <td>@shipment.Destination</td>
                            <td>
                                <span class="status-badge @GetStatusClass(shipment.Status)">
                                    @shipment.Status.GetDisplayName()
                                </span>
                            </td>
                            <td>@shipment.PickupDate.ToShortDateString()</td>
                            <td>@shipment.DeliveryDate?.ToShortDateString()</td>
                            <td>@shipment.WeightKg</td>
                            <td>@shipment.CustomerName</td>
                            <td>
                                <span class="badge bg-info">
                                    @shipment.InvoiceCount
                                </span>
                            </td>
                            <td>@shipment.CreatedDate.ToShortDateString()</td>
                            <td>@shipment.IsActive.ToString()</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="pagination-controls">

                <button class="btn btn-secondary"
                        disabled="@(pageNumber == 1)"
                        @onclick="PrevPage">
                    Previous
                </button>

                <span>Page @pageNumber</span>

                <button class="btn btn-secondary"
                        disabled="@((pageNumber * pageSize) >= totalCount)"
                        @onclick="NextPage">
                    Next
                </button>

            </div>
        }
    }
</div>

@code {
    private List<ShipmentResponseDto> shipments = new();
    [Parameter]
    [SupplyParameterFromQuery]
    public Guid? CustomerId { get; set; }
    private bool isLoading = true;
    private string? errorMessage;
    string searchTerm = "";
    string statusFilter = "";
    private string activeFilterString = "";
    bool? activeFilter = null;
    int pageNumber = 1;
    int pageSize = 10;
    int totalCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadShipments();
    }

    private async Task LoadShipments()
    {
        try
        {
            isLoading = true;
            var result = await ShipmentService.GetAllAsync(
                searchTerm,
                statusFilter,
                CustomerId,
                pageNumber,
                pageSize,
                activeFilter);

            shipments = result.Items;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading shipments: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetStatusClass(ShipmentStatus status)
    {
        return status switch
        {
            ShipmentStatus.Created => "status-created",
            ShipmentStatus.InTransit => "status-transit",
            ShipmentStatus.Delivered => "status-delivered",
            ShipmentStatus.Delayed => "status-delayed",
            ShipmentStatus.Cancelled => "status-cancelled",
            _ => ""
        };
    }

    async Task OnFilterChanged()
    {
        pageNumber = 1;
        await LoadShipments();
    }

    private async Task OnActiveChanged()
    {
        activeFilter = activeFilterString switch
        {
            "true" => true,
            "false" => false,
            _ => null
        };

        await OnFilterChanged();
    }

    async Task NextPage()
    {
        pageNumber++;
        await LoadShipments();
    }

    async Task PrevPage()
    {
        pageNumber--;
        await LoadShipments();
    }

    private void OpenShipment(Guid id)
    {
        NavigationManager.NavigateTo($"/shipment/{id}");
    }

    private void CreateShipment()
    {
        NavigationManager.NavigateTo("/edit-shipment");
    }
}