@page "/shipments"
@inject ShipmentService ShipmentService
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Shipments</h3>

    <button class="btn btn-success" @onclick="CreateShipment">
        + Create Shipment
    </button>
</div>

@if (isLoading)
{
    <p><em>Loading shipments...</em></p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (shipments.Count == 0)
{
    <p>No shipments found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Shipment #</th>
                <th>Origin</th>
                <th>Destination</th>
                <th>Status</th>
                <th>Pickup</th>
                <th>Delivery</th>
                <th>Weight (kg)</th>
                <th>Customer</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var shipment in shipments)
            {
                <tr>
                    <td>@shipment.ShipmentNumber</td>
                    <td>@shipment.Origin</td>
                    <td>@shipment.Destination</td>
                    <td>@shipment.Status</td>
                    <td>@shipment.PickupDate.ToShortDateString()</td>
                    <td>@shipment.DeliveryDate?.ToShortDateString()</td>
                    <td>@shipment.WeightKg</td>
                    <td>@shipment.CustomerCode</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="@(() => EditShipment(shipment.Id))">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteShipment(shipment.Id))">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Shipment> shipments = new();
    private bool isLoading = true;
    private string? errorMessage;
    //[Inject] private NavigationManager NavigationManager { get; set; } = default!;
    //[Inject] private IJSRuntime JsRuntime { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadShipments();
    }

    private async Task LoadShipments()
    {
        try
        {
            isLoading = true;
            shipments = await ShipmentService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading shipments: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateShipment()
    {
        NavigationManager.NavigateTo("/edit-shipment");
    }

    private async Task EditShipment(Guid id)
    {
        NavigationManager.NavigateTo($"/edit-shipment/{id}");
    }

    private async Task DeleteShipment(Guid id)
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this shipment?"))
        {
            try
            {
                await ShipmentService.DeleteAsync(id);
                await LoadShipments(); // refresh list
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting shipment: {ex.Message}";
            }
        }
    }
}