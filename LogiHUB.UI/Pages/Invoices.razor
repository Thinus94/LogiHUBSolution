@page "/invoices"

@inject InvoiceService InvoiceService
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<div class="page-blur-container">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Invoices</h3>

        <button class="btn btn-success"
                @onclick="CreateInvoice">
            + Create Invoice
        </button>
    </div>

    @if (showInvoiceModal && selectedInvoice != null)
    {
        <div class="modal-overlay">
            <div class="modal-card">

                <div class="modal-header">
                    <h4>Invoice Details</h4>
                    <button class="btn-close"
                            @onclick="CloseInvoiceModal"></button>
                </div>

                <div class="modal-body">

                    <p><b>Invoice:</b> @selectedInvoice.InvoiceNumber</p>

                    <p>
                        <b>Status:</b>
                        <span class="status-badge @GetStatusClass(selectedInvoice.Status)">
                            @selectedInvoice.Status
                        </span>
                    </p>

                    <p><b>Amount:</b> €@selectedInvoice.Amount</p>
                    <p><b>Customer:</b> @selectedInvoice.CustomerName</p>
                    <p><b>Shipment:</b> @selectedInvoice.ShipmentNumber</p>

                    <p><b>Issued:</b> @selectedInvoice.IssueDate.ToShortDateString()</p>
                    <p><b>Due:</b> @selectedInvoice.DueDate?.ToShortDateString()</p>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-primary"
                            @onclick="@(() => EditInvoice(selectedInvoice.Id))">
                        Edit
                    </button>
                    <button class="btn btn-secondary"
                            @onclick="CloseInvoiceModal">
                        Close
                    </button>
                    <button class="btn btn-sm btn-outline-primary"
                            @onclick="() => OpenCustomer(selectedInvoice.CustomerId)">
                        Open Customer: @selectedInvoice.CustomerName
                    </button>

                    @if (selectedInvoice.ShipmentId.HasValue)
                    {
                        <button class="btn btn-sm btn-outline-info"
                                @onclick="() => OpenShipment(selectedInvoice.ShipmentId)">
                            Open Shipment: @selectedInvoice.ShipmentNumber
                        </button>
                    }
                </div>

            </div>
        </div>
    }

    @if (isLoading)
    {
        <p><em>Loading invoices...</em></p>
    }
    else if (invoices.Count == 0)
    {
        <p>No invoices found.</p>
    }
    else
    {
        <div class="table-responsive table-container">

            <table class="table table-glass table-hover">

                <thead>
                    <tr>
                        <th>Invoice</th>
                        <th>Status</th>
                        <th>Amount</th>
                        <th>Customer</th>
                        <th>Shipment</th>
                        <th>Issued</th>
                        <th>Due</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var invoice in invoices)
                    {
                        <tr @onclick="() => OpenInvoice(invoice)">

                            <td>@invoice.InvoiceNumber</td>

                            <td>
                                <span class="status-badge @GetStatusClass(invoice.Status)">
                                    @invoice.Status
                                </span>
                            </td>

                            <td>€@invoice.Amount</td>

                            <td>@invoice.CustomerName</td>

                            <td>@invoice.ShipmentNumber</td>

                            <td>@invoice.IssueDate.ToShortDateString()</td>

                            <td>@invoice.DueDate?.ToShortDateString()</td>

                            <td>

                                <button class="btn btn-sm btn-primary"
                                        @onclick:stopPropagation="true"
                                        @onclick="@(() => EditInvoice(invoice.Id))">
                                    Edit
                                </button>

                                <button class="btn btn-sm btn-danger"
                                        @onclick:stopPropagation="true"
                                        @onclick="@(() => DeleteInvoice(invoice.Id))">
                                    Delete
                                </button>

                            </td>

                        </tr>
                    }

                </tbody>
            </table>

        </div>
    }

</div>

@code {

    private List<InvoiceResponseDto> invoices = new();

    private InvoiceResponseDto? selectedInvoice;

    [Parameter]
    [SupplyParameterFromQuery]
    public Guid? CustomerId { get; set; }

    private bool showInvoiceModal;

    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadInvoices();
    }

    private async Task LoadInvoices()
    {
        isLoading = true;

        invoices = await InvoiceService.GetAllAsync(CustomerId);

        isLoading = false;
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Paid" => "status-paid",
            "Pending" => "status-pending",
            "Overdue" => "status-overdue",
            _ => ""
        };
    }

    private void OpenInvoice(InvoiceResponseDto invoice)
    {
        selectedInvoice = invoice;
        showInvoiceModal = true;
    }

    private void CloseInvoiceModal()
    {
        showInvoiceModal = false;
    }

    void OpenShipment(Guid? shipmentId)
    {
        if (shipmentId.HasValue)
        {
            NavigationManager.NavigateTo($"/edit-shipment/{shipmentId.Value}");
        }
    }

    void OpenCustomer(Guid customerId)
    {
        NavigationManager.NavigateTo($"/edit-customer/{customerId}");
    }

    private void CreateInvoice()
    {
        NavigationManager.NavigateTo("/edit-invoice");
    }

    private void EditInvoice(Guid id)
    {
        NavigationManager.NavigateTo($"/edit-invoice/{id}");
    }

    private async Task DeleteInvoice(Guid id)
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", "Delete invoice?"))
        {
            await InvoiceService.DeleteAsync(id);
            await LoadInvoices();
        }
    }

}