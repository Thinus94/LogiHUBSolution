@page "/invoices"

<PageTitle>Invoices</PageTitle>

<div class="invoices-page page-blur-container">
    <h1>Invoices</h1>
    <p>Manage all invoices generated from shipments. View, create, and track invoices with ease.</p>

    <button class="btn btn-success mb-3">+ Create Invoice</button>

    <table class="table table-striped table-glass">
        <thead>
        <tr>
            <th>Invoice Number</th>
            <th>Shipment Number</th>
            <th>Customer</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        <!-- invoice rows will go here -->
        </tbody>
    </table>
</div>