@page "/customer/{Id:guid}"

@inject CustomerService CustomerService
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<div class="page-blur-container">

    @if (customer == null)
    {
        <p>Loading customer...</p>
    }
    else
    {
        <h3>@customer.Name</h3>

        <div class="details-card">

            <div class="details-grid">

                <div><b>Email:</b> @customer.Email</div>
                <div><b>Phone:</b> @customer.Phone</div>
                <div><b>Address:</b> @customer.Address</div>
                <div><b>Shipments:</b> @customer.ShipmentCount</div>
                <div><b>Invoices:</b> @customer.InvoiceCount</div>

            </div>

            <div class="mt-3 d-flex gap-2">

                <button class="btn btn-primary" @onclick="UpdateCustomer">
                    Update
                </button>

                @if (customer.ShipmentCount > 0)
                {
                    <button class="btn btn-info" @onclick="ViewShipments">
                        View Shipments
                    </button>
                }

                @if (customer.InvoiceCount > 0)
                {
                    <button class="btn btn-success" @onclick="ViewInvoices">
                        View Invoices
                    </button>
                }
                
                @if (CanDeleteCustomer)
                {
                    <button class="btn btn-sm btn-danger"
                            @onclick:stopPropagation="true"
                            @onclick="@(() => DeleteCustomer(customer.Id))">
                        Delete
                    </button>
                }

            </div>
        </div>
    }

</div>

@code {

    [Parameter] public Guid Id { get; set; }

    CustomerResponseDto? customer;

    bool CanDeleteCustomer => customer != null && customer.ShipmentCount == 0 && customer.InvoiceCount == 0;

    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        customer = await CustomerService.GetByIdAsync(Id);
    }

    void UpdateCustomer()
    {
        NavigationManager.NavigateTo("/edit-customer/" + customer!.Id);
    }

    void ViewShipments()
    {
        NavigationManager.NavigateTo("/shipments?customerId=" + customer!.Id);
    }

    void ViewInvoices()
    {
        NavigationManager.NavigateTo("/invoices?customerId=" + customer!.Id);
    }

    private async Task DeleteCustomer(Guid id)
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this customer?"))
        {
            try
            {
                await CustomerService.DeleteAsync(id);
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting customer: {ex.Message}";
            }
        }
        NavigationManager.NavigateTo("/customers");
    }
}