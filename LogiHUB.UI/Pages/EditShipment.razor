@page "/edit-shipment"
@page "/edit-shipment/{Id:guid}"

@inject ShipmentService ShipmentService
@inject CustomerService CustomerService
@inject NavigationManager NavigationManager

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else
{

    <div class="page-blur-container">
        <h3>@(IsEditMode ? "Edit Shipment" : "Create Shipment")</h3>

        <EditForm Model="FormModel"
                  OnValidSubmit="HandleValidSubmit"
                  FormName="ShipmentForm">

            <DataAnnotationsValidator />
            <ValidationSummary />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            @if (IsEditMode)
            {
                @if (IsEditMode)
                {
                    <div class="mb-3">
                        <label class="form-label">Shipment Number</label>
                        <InputText class="form-control"
                                   @bind-Value="ShipmentNumber"
                                   readonly />
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Status</label>
                    <InputSelect class="form-control" @bind-Value="editDto.Status">
                        <option value="Created">Created</option>
                        <option value="In Transit">In Transit</option>
                        <option value="Delivered">Delivered</option>
                        <option value="Delayed">Delayed</option>
                        <option value="Cancelled">Cancelled</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => editDto.Status)" />
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Origin</label>

                @if (IsEditMode)
                {
                    <InputText class="form-control" @bind-Value="editDto.Origin" />
                    <ValidationMessage For="@(() => editDto.Origin)" />
                }
                else
                {
                    <InputText class="form-control" @bind-Value="createDto.Origin" />
                    <ValidationMessage For="@(() => createDto.Origin)" />
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Destination</label>

                @if (IsEditMode)
                {
                    <InputText class="form-control" @bind-Value="editDto.Destination" />
                    <ValidationMessage For="@(() => editDto.Destination)" />
                }
                else
                {
                    <InputText class="form-control" @bind-Value="createDto.Destination" />
                    <ValidationMessage For="@(() => createDto.Destination)" />
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Pickup Date</label>

                @if (IsEditMode)
                {
                    <InputDate class="form-control" @bind-Value="editDto.PickupDate" />
                    <ValidationMessage For="@(() => editDto.PickupDate)" />
                }
                else
                {
                    <InputDate class="form-control" @bind-Value="createDto.PickupDate" />
                    <ValidationMessage For="@(() => createDto.PickupDate)" />
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Delivery Date</label>

                @if (IsEditMode)
                {
                    <InputDate class="form-control" @bind-Value="editDto.DeliveryDate" />
                }
                else
                {
                    <InputDate class="form-control" @bind-Value="createDto.DeliveryDate" />
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Weight (kg)</label>

                @if (IsEditMode)
                {
                    <InputNumber class="form-control" @bind-Value="editDto.WeightKg" />
                    <ValidationMessage For="@(() => editDto.WeightKg)" />
                }
                else
                {
                    <InputNumber class="form-control" @bind-Value="createDto.WeightKg" />
                    <ValidationMessage For="@(() => createDto.WeightKg)" />
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Customer</label>

                @if (IsEditMode)
                {
                    <InputSelect class="form-control" @bind-Value="editDto.CustomerId">
                        <option value="">-- Select Customer --</option>
                        @foreach (var c in customers)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => editDto.CustomerId)" />
                }
                else
                {
                    <InputSelect class="form-control" @bind-Value="createDto.CustomerId">
                        <option value="">-- Select Customer --</option>
                        @foreach (var c in customers)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => createDto.CustomerId)" />
                }
        </div>

        <button type="submit" class="btn btn-success me-2">
            @(IsEditMode ? "Update" : "Create")
        </button>

        <button type="button"
                class="btn btn-secondary"
                @onclick="Cancel">
            Cancel
        </button>

    </EditForm>
</div>
}

@code {

[Parameter] public Guid? Id { get; set; }

    private bool IsEditMode => Id.HasValue;
    private bool isLoading = false;

    private string? errorMessage;

    private List<CustomerResponseDto> customers = new();

    private CreateShipmentDto createDto = new();
    private UpdateShipmentDto editDto = new();

    private string ShipmentNumber = "";

    private object FormModel => IsEditMode ? editDto : createDto;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;

            customers = await CustomerService.GetAllAsync();

            if (IsEditMode)
            {
                var shipmentResponse = await ShipmentService.GetByIdAsync(Id!.Value);
                if (shipmentResponse == null)
                {
                    errorMessage = "Shipment not found.";
                    return;
                }

                // Map to editDto
                editDto = new UpdateShipmentDto
                {
                    Id = shipmentResponse.Id,
                    ShipmentNumber = shipmentResponse.ShipmentNumber,
                    Status = shipmentResponse.Status,
                    Origin = shipmentResponse.Origin,
                    Destination = shipmentResponse.Destination,
                    PickupDate = shipmentResponse.PickupDate,
                    DeliveryDate = shipmentResponse.DeliveryDate,
                    WeightKg = shipmentResponse.WeightKg,
                    CustomerId = shipmentResponse.CustomerId
                };

                // Store ShipmentNumber separately for display
                ShipmentNumber = shipmentResponse.ShipmentNumber;
            }
            else
            {
                createDto.PickupDate = DateTime.Today;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (IsEditMode)
            {
                await ShipmentService.UpdateAsync(editDto);
            }
            else
            {
                await ShipmentService.CreateAsync(createDto);
            }

            NavigationManager.NavigateTo("/shipments");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving shipment: {ex.Message}";
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/shipments");
    }

}
