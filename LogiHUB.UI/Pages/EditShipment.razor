@page "/edit-shipment"
@page "/edit-shipment/{Id:guid}"

@inject ShipmentService ShipmentService
@inject NavigationManager NavigationManager

<h3>@(IsEditMode ? "Edit Shipment" : "Create Shipment")</h3>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="shipment"
              OnValidSubmit="HandleValidSubmit"
              FormName="ShipmentForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div class="mb-3">
            <label class="form-label">Shipment Number</label>
            <InputText class="form-control" @bind-Value="shipment.ShipmentNumber" />
            <ValidationMessage For="@(() => shipment.ShipmentNumber)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Origin</label>
            <InputText class="form-control" @bind-Value="shipment.Origin" />
            <ValidationMessage For="@(() => shipment.Origin)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Destination</label>
            <InputText class="form-control" @bind-Value="shipment.Destination" />
            <ValidationMessage For="@(() => shipment.Destination)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <InputText class="form-control" @bind-Value="shipment.Status" />
            <ValidationMessage For="@(() => shipment.Status)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Pickup Date</label>
            <InputDate class="form-control" @bind-Value="shipment.PickupDate" />
            <ValidationMessage For="@(() => shipment.PickupDate)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Delivery Date</label>
            <InputDate class="form-control" @bind-Value="shipment.DeliveryDate" />
        </div>

        <div class="mb-3">
            <label class="form-label">Weight (kg)</label>
            <InputNumber class="form-control" @bind-Value="shipment.WeightKg" />
            <ValidationMessage For="@(() => shipment.WeightKg)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Customer Code</label>
            <InputText class="form-control" @bind-Value="shipment.CustomerCode" />
            <ValidationMessage For="@(() => shipment.CustomerCode)" />
        </div>

        <button type="submit" class="btn btn-success me-2">
            @(IsEditMode ? "Update" : "Create")
        </button>

        <button type="button" class="btn btn-secondary" @onclick="Cancel">
            Cancel
        </button>
    </EditForm>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private Shipment shipment = new();
    private bool isLoading = false;
    private bool IsEditMode => Id.HasValue;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode)
        {
            try
            {
                isLoading = true;
                var existing = await ShipmentService.GetByIdAsync(Id!.Value);

                if (existing == null)
                {
                    errorMessage = "Shipment not found.";
                    return;
                }

                shipment = existing;
            }
            catch (Exception ex)
            {
                errorMessage = $"Error loading shipment: {ex.Message}";
            }
            finally
            {
                isLoading = false;
            }
        }
        else
        {
            shipment.PickupDate = DateTime.Today;
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (IsEditMode)
            {
                await ShipmentService.UpdateAsync(shipment);
            }
            else
            {
                await ShipmentService.CreateAsync(shipment);
            }

            NavigationManager.NavigateTo("/shipments");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving shipment: {ex.Message}";
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/shipments");
    }
}