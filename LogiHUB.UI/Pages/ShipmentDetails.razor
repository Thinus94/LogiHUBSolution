@page "/shipment/{Id:guid}"

@inject ShipmentService ShipmentService
@inject InvoiceService InvoiceService
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<div class="page-blur-container">

@if (shipment == null)
{
    <p>Loading...</p>
}
else
{
    <h3>Shipment @shipment.ShipmentNumber</h3>

        <ShipmentTimeline Status="@shipment.Status" />

        <div class="details-card">

            <div class="details-grid">

                <div>
                    <b>Status</b>
                    <span class="status-badge @GetStatusClass(shipment.Status)">
                        @shipment.Status.GetDisplayName()
                    </span>
                </div>

                <div><b>Origin</b> @shipment.Origin</div>
                <div><b>Destination</b> @shipment.Destination</div>
                <div><b>Weight</b> @shipment.WeightKg kg</div>
                <div><b>Pickup</b> @shipment.PickupDate.ToShortDateString()</div>
                <div><b>Delivery</b> @shipment.DeliveryDate?.ToShortDateString()</div>

                <div>
                    <b>Customer</b>
                    <button class="btn btn-secondary"
                            @onclick="OpenCustomer">
                        @shipment.CustomerName
                    </button>
                </div>

            </div>
        </div>

        @if (invoices.Count > 0)
        {
            <div class="details-card mt-4">

                <h4 class="mb-3">Invoices</h4>
                
                @if (invoices.Count == 0)
                {
                    <p class="text-muted">No invoices created for this shipment.</p>
                }
                else
                {
                    <table class="table table-glass table-hover">

                        <thead>
                        <tr>
                            <th>Invoice</th>
                            <th>Status</th>
                            <th>Amount</th>
                            <th>Issued</th>
                            <th>Due</th>
                        </tr>
                        </thead>

                        <tbody>

                        @foreach (var invoice in invoices)
                        {
                            <tr @onclick="() => OpenInvoice(invoice.Id)">
                                <td>@invoice.InvoiceNumber</td>
                                <td>
                                    <span class="status-badge @GetInvoiceStatusClass(invoice.Status)">
                                        @invoice.Status.GetDisplayName()
                                    </span>
                                </td>
                                <td>€@invoice.Amount</td>
                                <td>@invoice.IssueDate.ToShortDateString()</td>
                                <td>@invoice.DueDate?.ToShortDateString()</td>
                            </tr>
                        }

                        </tbody>

                    </table>
                }
            </div>
        }

        <div class="mt-3 d-flex gap-2">
            
            @if (CanEditShipment)
            {
                <button class="btn btn-primary"
                        @onclick="UpdateShipment">
                    Update
                </button>
            }
            <button class="btn btn-success"
                    @onclick="CreateInvoice">
                + Create Invoice
            </button>
            @if (shipment.InvoiceCount > 0)
            {
                <button class="btn btn-secondary"
                        @onclick="OpenShipmentInvoices">
                    View Invoices (@shipment.InvoiceCount)
                </button>
            }
            @if (shipment.Status == ShipmentStatus.Created && shipment.InvoiceCount == 0)
            {
                <button class="btn btn-sm btn-danger"
                        @onclick:stopPropagation="true"
                        @onclick="@(() => DeleteShipment(shipment.Id))">
                    Delete
                </button>
            }

        </div>
}

</div>

@code {

    [Parameter] public Guid Id { get; set; }

    ShipmentResponseDto? shipment;

    List<InvoiceResponseDto> invoices = new();

    bool CanEditShipment => shipment != null && shipment.Status != ShipmentStatus.Delivered && shipment.Status != ShipmentStatus.Cancelled && shipment.Status != ShipmentStatus.InTransit;

    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        shipment = await ShipmentService.GetByIdAsync(Id);

        if (shipment != null)
        {
            invoices = await InvoiceService.GetAllAsync(null);
            invoices = invoices.Where(i => i.ShipmentId == shipment.Id).ToList();
        }
    }

    void OpenCustomer()
    {
        NavigationManager.NavigateTo("/customer/" + shipment!.CustomerId);
    }

    void UpdateShipment()
    {
        NavigationManager.NavigateTo("/edit-shipment/" + shipment!.Id);
    }

    void OpenShipmentInvoices()
    {
        NavigationManager.NavigateTo($"/invoices?shipmentId={shipment!.Id}");
    }

    void OpenInvoice(Guid invoiceId)
    {
        NavigationManager.NavigateTo("/invoice/" + invoiceId);
    }

    void CreateInvoice()
    {
        NavigationManager.NavigateTo($"/edit-invoice?shipmentId={shipment!.Id}&customerId={shipment.CustomerId}");
    }

    private async Task DeleteShipment(Guid id)
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this shipment?"))
        {
            try
            {
                await ShipmentService.DeleteAsync(id);
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting shipment: {ex.Message}";
            }
        }
        NavigationManager.NavigateTo("/shipments");
    }

string GetStatusClass(ShipmentStatus status)
{
    return status switch
    {
        ShipmentStatus.Created => "status-created",
        ShipmentStatus.InTransit => "status-transit",
        ShipmentStatus.Delivered => "status-delivered",
        ShipmentStatus.Delayed => "status-delayed",
        ShipmentStatus.Cancelled => "status-cancelled",
        _ => ""
    };
}

    string GetInvoiceStatusClass(InvoiceStatus status)
    {
        return status switch
        {
            InvoiceStatus.Paid => "status-paid",
            InvoiceStatus.Pending => "status-pending",
            InvoiceStatus.Overdue => "status-overdue",
            InvoiceStatus.Cancelled => "status-cancelled",
            _ => ""
        };
    }

}