@page "/dashboard"

@inject HttpClient Http

<div class="dashboard">
    <h2>Dashboard</h2>

    <div class="dashboard-groups">

        <!-- Totals Group -->
        <div class="dashboard-card">
            <h3 class="card-title">Totals</h3>
            <div class="dashboard-group totals-group">
                <div class="stat-card stat-card-shipments">
                    <h4>Shipments</h4>
                    <p>@shipmentCount</p>
                </div>

                <div class="stat-card stat-card-customers">
                    <h4>Customers</h4>
                    <p>@customerCount</p>
                </div>
            </div>
        </div>

        <!-- Statuses Group -->
        <div class="dashboard-card">
            <h3 class="card-title">Shipment Statuses</h3>
            <div class="dashboard-group statuses-group">
                <div class="stat-card stat-card-created">
                    <h4>Created</h4>
                    <p>@createdCount</p>
                </div>

                <div class="stat-card stat-card-intransit">
                    <h4>In Transit</h4>
                    <p>@inTransitCount</p>
                </div>

                <div class="stat-card stat-card-delivered">
                    <h4>Delivered</h4>
                    <p>@deliveredCount</p>
                </div>

                <div class="stat-card stat-card-delayed">
                    <h4>Delayed</h4>
                    <p>@delayedCount</p>
                </div>

                <div class="stat-card stat-card-cancelled">
                    <h4>Cancelled</h4>
                    <p>@cancelledCount</p>
                </div>
            </div>
        </div>
        
        <!-- Financial Group -->
        <div class="dashboard-card">

            <h3 class="card-title">Financials</h3>

            <div class="dashboard-group">

                <div class="stat-card stat-card-revenue">
                    <h4>Total Revenue</h4>
                    <p>€@totalRevenue</p>
                </div>

                <div class="stat-card stat-card-paid">
                    <h4>Paid</h4>
                    <p>€@paid</p>
                </div>

                <div class="stat-card stat-card-outstanding">
                    <h4>Outstanding</h4>
                    <p>€@outstanding</p>
                </div>

                <div class="stat-card stat-card-overdue">
                    <h4>Overdue</h4>
                    <p>€@overdue</p>
                </div>

            </div>

        </div>

    </div>
</div>

@code {
    private int shipmentCount;
    private int customerCount;
    private int createdCount;
    private int inTransitCount;
    private int deliveredCount;
    private int delayedCount;
    private int cancelledCount;
    private decimal totalRevenue;
    private decimal outstanding;
    private decimal overdue;
    private decimal paid;

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();
    }

    private async Task LoadStats()
    {
        try
        {
            var shipmentResult = await Http.GetFromJsonAsync<PagedResult<ShipmentResponseDto>>(
                "api/shipments?pageNumber=1&pageSize=1000");

            var customers = await Http.GetFromJsonAsync<List<CustomerResponseDto>>("api/customers");

            var shipments = shipmentResult?.Items ?? new List<ShipmentResponseDto>();

            shipmentCount = shipments.Count;
            customerCount = customers?.Count ?? 0;

            createdCount = shipments.Count(s => s.Status == "Created");
            inTransitCount = shipments.Count(s => s.Status == "In Transit");
            deliveredCount = shipments.Count(s => s.Status == "Delivered");
            delayedCount = shipments.Count(s => s.Status == "Delayed");
            cancelledCount = shipments.Count(s => s.Status == "Cancelled");

            var invoices = await Http.GetFromJsonAsync<List<InvoiceResponseDto>>("api/invoices")
                           ?? new List<InvoiceResponseDto>();

            totalRevenue = invoices.Sum(i => i.Amount);

            paid = invoices
                .Where(i => i.Status == "Paid")
                .Sum(i => i.Amount);

            outstanding = invoices
                .Where(i => i.Status == "Pending")
                .Sum(i => i.Amount);

            overdue = invoices
                .Where(i => i.Status == "Overdue")
                .Sum(i => i.Amount);
        }
        catch
        {
            // ignore errors
        }
    }
}