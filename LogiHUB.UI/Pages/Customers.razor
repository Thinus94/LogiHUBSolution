@page "/customers"
@inject CustomerService CustomerService
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<div class="page-blur-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Customers</h3>
        <button class="btn btn-success" @onclick="CreateCustomer">+ Add Customer</button>
    </div>
    
    @if (showCustomerModal && selectedCustomer != null)
    {
        <div class="modal-overlay">
            <div class="modal-card">

                <div class="modal-header">
                    <h4>Customer Details</h4>
                    <button class="btn-close" @onclick="CloseCustomerModal"></button>
                </div>

                <div class="modal-body">

                    <p><b>Name:</b> @selectedCustomer.Name</p>
                    <p><b>Email:</b> @selectedCustomer.Email</p>
                    <p><b>Phone:</b> @selectedCustomer.Phone</p>
                    <p><b>Address:</b> @selectedCustomer.Address</p>
                    <p><b>Shipments:</b> @selectedCustomer.ShipmentCount</p>

                </div>
                @if (selectedCustomer.ShipmentCount > 0)
                {
                    <button class="btn btn-primary"
                            @onclick="() => OpenCustomerShipments(selectedCustomer.Id)">
                        View Shipments (@selectedCustomer.ShipmentCount)
                    </button>
                }

                @if (selectedCustomer.InvoiceCount > 0)
                {
                    <button class="btn btn-success"
                            @onclick="() => OpenCustomerInvoices(selectedCustomer.Id)">
                        View Invoices (@selectedCustomer.InvoiceCount)
                    </button>
                }
                <div class="modal-footer">
                    <button class="btn btn-primary"
                            @onclick="@(() => EditCustomer(selectedCustomer.Id))">
                        Edit
                    </button>

                    <button class="btn btn-secondary"
                            @onclick="CloseCustomerModal">
                        Close
                    </button>
                </div>

            </div>
        </div>
    }

    @if (isLoading)
    {
        <p><em>Loading customers...</em></p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (customers.Count == 0)
    {
        <p>No customers found.</p>
    }
    else
    {
        <div class="table-responsive table-container">
            <table class="table table-glass table-hover">
                <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var customer in customers)
                {
                    <tr @onclick="() => OpenCustomer(customer)">
                        <td>@customer.Name</td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.Address</td>
                        <td>
                            <button class="btn btn-sm btn-primary"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => EditCustomer(customer.Id))">
                                Edit
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => DeleteCustomer(customer.Id))">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<CustomerResponseDto> customers = new();
    private CustomerResponseDto? selectedCustomer;
    private bool showCustomerModal = false;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        try
        {
            isLoading = true;
            customers = await CustomerService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading customers: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCustomer(CustomerResponseDto customer)
    {
        selectedCustomer = customer;
        showCustomerModal = true;
    }

    void OpenCustomerShipments(Guid customerId)
    {
        NavigationManager.NavigateTo($"/shipments?customerId={customerId}");
    }

    void OpenCustomerInvoices(Guid customerId)
    {
        NavigationManager.NavigateTo($"/invoices?customerId={customerId}");
    }

    private void CloseCustomerModal()
    {
        showCustomerModal = false;
    }

    private void CreateCustomer() => NavigationManager.NavigateTo("/edit-customer");

    private void EditCustomer(Guid id) => NavigationManager.NavigateTo($"/edit-customer/{id}");

    private async Task DeleteCustomer(Guid id)
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this customer?"))
        {
            try
            {
                await CustomerService.DeleteAsync(id);
                await LoadCustomers();
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting customer: {ex.Message}";
            }
        }
    }
}