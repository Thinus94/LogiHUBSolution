@page "/customers"
@inject CustomerService CustomerService
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<div class="page-blur-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Customers</h3>
        <button class="btn btn-success" @onclick="CreateCustomer">+ Add Customer</button>
    </div>

    @if (isLoading)
    {
        <p><em>Loading customers...</em></p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (customers.Count == 0)
    {
        <p>No customers found.</p>
    }
    else
    {
        <div class="table-responsive table-container">
            <table class="table table-glass table-hover">
                <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var customer in customers)
                {
                    <tr @onclick="() => OpenCustomer(customer.Id)">
                        <td>@customer.Name</td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.Address</td>
                        <td>
                            <button class="btn btn-sm btn-primary"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => EditCustomer(customer.Id))">
                                Edit
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => DeleteCustomer(customer.Id))">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<CustomerResponseDto> customers = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        try
        {
            isLoading = true;
            customers = await CustomerService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading customers: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCustomer(Guid id)
    {
        NavigationManager.NavigateTo($"/customer/{id}");
    }

    private void CreateCustomer() => NavigationManager.NavigateTo("/edit-customer");

    private void EditCustomer(Guid id) => NavigationManager.NavigateTo($"/edit-customer/{id}");

    private async Task DeleteCustomer(Guid id)
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this customer?"))
        {
            try
            {
                await CustomerService.DeleteAsync(id);
                await LoadCustomers();
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting customer: {ex.Message}";
            }
        }
    }
}